# Server
PORT=3000
NODE_ENV=development

# Database Configuration (Local MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=twouple_db

# Database Configuration (Production PostgreSQL via Render)
# If this is set, the app will use PostgreSQL instead of MySQL
# DATABASE_URL=postgres://user:password@hostname:port/dbname

# Security
JWT_SECRET=generate_a_64_char_random_string_here

# OTP — Set to 'true' in production to send real SMS
USE_REAL_OTP=false

# Twilio SMS
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# AI Engine (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
